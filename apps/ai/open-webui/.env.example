# ==============================================================================
# OPEN WEBUI CONFIGURATION EXAMPLE
# Copy this file to /opt/ai/open-webui/.env and customize
# ==============================================================================

# Application Settings
WEBUI_NAME=Open WebUI
WEBUI_SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
DATA_DIR=/app/backend/data

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Ollama Configuration
# If Ollama is running, set the URL here
# Format: http://ollama:11434 (for Docker) or http://localhost:11434 (for local)
OLLAMA_BASE_URL=http://ollama:11434
ENABLE_OLLAMA_API=true

# OpenAI Configuration (optional)
# Uncomment and set your API key to use OpenAI models
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Other OpenAI-compatible APIs
# OPENAI_API_KEY=your-api-key
# OPENAI_API_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_BASE_URL=https://api.together.xyz/v1
# OPENAI_API_BASE_URL=http://localhost:1234/v1

# Authentication Settings
ENABLE_SIGNUP=true
DEFAULT_USER_ROLE=user
ENABLE_LOGIN_FORM=true

# User Management
# JWT_EXPIRES_IN=-1
# ENABLE_API_KEY=true

# RAG (Retrieval Augmented Generation)
# Vector database for document storage
VECTOR_DB=chroma
CHROMA_DATA_PATH=/app/backend/data/vector_db
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# Embedding Model
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SENTENCE_TRANSFORMERS_HOME=/app/backend/data/cache/embedding/models

# Optional: Use external embedding service
# RAG_EMBEDDING_ENGINE=openai
# RAG_EMBEDDING_OPENAI_BATCH_SIZE=1

# Reranking Model (optional, improves RAG results)
# RAG_RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Whisper (Speech to Text)
WHISPER_MODEL=base
WHISPER_MODEL_DIR=/app/backend/data/cache/whisper/models

# Alternative: Use OpenAI Whisper API
# AUDIO_STT_ENGINE=openai
# AUDIO_STT_OPENAI_API_KEY=sk-your-key

# Text to Speech
# AUDIO_TTS_ENGINE=openai
# AUDIO_TTS_OPENAI_API_KEY=sk-your-key
# AUDIO_TTS_VOICE=alloy

# Image Generation
# ENABLE_IMAGE_GENERATION=true
# IMAGE_GENERATION_ENGINE=automatic1111
# AUTOMATIC1111_BASE_URL=http://localhost:7860

# Or use OpenAI DALL-E
# IMAGE_GENERATION_ENGINE=openai
# IMAGES_OPENAI_API_KEY=sk-your-key

# Or use ComfyUI
# IMAGE_GENERATION_ENGINE=comfyui
# COMFYUI_BASE_URL=http://localhost:8188

# Web Search
# ENABLE_RAG_WEB_SEARCH=true
# RAG_WEB_SEARCH_ENGINE=searxng
# SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>

# Alternative search engines:
# RAG_WEB_SEARCH_ENGINE=duckduckgo
# RAG_WEB_SEARCH_ENGINE=google_pse
# GOOGLE_PSE_API_KEY=your-key
# GOOGLE_PSE_ENGINE_ID=your-engine-id

# RAG_WEB_SEARCH_ENGINE=brave
# BRAVE_SEARCH_API_KEY=your-key

# RAG_WEB_SEARCH_ENGINE=serpstack
# SERPSTACK_API_KEY=your-key

# Content Extraction
# CONTENT_EXTRACTION_ENGINE=tika
# TIKA_SERVER_URL=http://tika:9998

# YouTube Transcript
# YOUTUBE_LOADER_LANGUAGE=en,es,fr

# Logs and Monitoring
GLOBAL_LOG_LEVEL=INFO
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# Database
# Default: SQLite
DATABASE_URL=sqlite:///app/backend/data/webui.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@postgres:5432/openwebui

# ==============================================================================
# ADVANCED SETTINGS
# ==============================================================================

# Session Configuration
WEBUI_SESSION_COOKIE_SAME_SITE=lax
WEBUI_SESSION_COOKIE_SECURE=false

# Model Settings
# Filter which models users can see
# ENABLE_MODEL_FILTER=true
# MODEL_FILTER_LIST=llama2,mistral,codellama

# BYPASS_MODEL_ACCESS_CONTROL=false

# Task Settings
ENABLE_AUTOCOMPLETE_GENERATION=false
# AUTOCOMPLETE_GENERATION_INPUT_MAX_LENGTH=0

# Follow-up suggestions
# ENABLE_FOLLOW_UP_GENERATION=true

# Title generation
# ENABLE_TITLE_GENERATION=true

# Tags generation
# ENABLE_TAGS_GENERATION=true

# Code Execution
ENABLE_CODE_EXECUTION=true
CODE_EXECUTION_ENGINE=pyodide

# Or use Jupyter
# CODE_EXECUTION_ENGINE=jupyter
# CODE_EXECUTION_JUPYTER_URL=http://jupyter:8888

# File Upload
# ENABLE_RAG_LOCAL_WEB_FETCH=false
# ENABLE_RAG_WEB_LOADER_SSL_VERIFICATION=true

# PDF Loader
# PDF_EXTRACT_IMAGES=false

# Webhook
# WEBHOOK_URL=https://your-webhook-url.com

# LDAP Authentication
# ENABLE_LDAP=false
# LDAP_SERVER_URL=ldap://ldap.example.com
# LDAP_BIND_DN=cn=admin,dc=example,dc=com
# LDAP_BIND_PASSWORD=password
# LDAP_USER_BASE=ou=users,dc=example,dc=com
# LDAP_USER_FILTER=(uid={username})

# OAuth Configuration
# ENABLE_OAUTH_SIGNUP=true
# OAUTH_USERNAME_CLAIM=preferred_username
# OAUTH_EMAIL_CLAIM=email
# OAUTH_PROVIDER_NAME=Your OAuth Provider
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_SCOPES=openid profile email
# OPENID_PROVIDER_URL=https://your-oauth-provider.com/.well-known/openid-configuration

# Redis (for scaling across multiple instances)
# REDIS_URL=redis://redis:6379/0
# REDIS_CLUSTER=false

# OpenTelemetry (monitoring)
# ENABLE_OPENTELEMETRY=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Custom Banner
# ENABLE_COMMUNITY_SHARING=true
# WEBUI_BANNER_URL=https://your-banner-url.com/banner.png
